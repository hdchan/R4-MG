{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Run Debug",
            "type": "debugpy",
            "request": "launch",
            "program": "./app_ui.py",
            "console": "integratedTerminal",
            // https://stackoverflow.com/questions/71834240/how-to-debug-pyqt5-threads-in-visual-studio-code
            "qt": "pyside",
            "justMyCode": false,
            "env": {
                "http_proxy": "http://127.0.0.1:9090",
                "https_proxy": "http://127.0.0.1:9090",
                "PYTHONHTTPSVERIFY": "0"
                // "REQUESTS_CA_BUNDLE": "C:\\Users\\henry\\AppData\\Roaming\\Proxyman\\certificate\\certs\\ca.pem",
                // "SSL_CERT_FILE": "C:\\Users\\henry\\AppData\\Roaming\\Proxyman\\certificate\\certs\\ca.pem"
            }
        }
    ]
}